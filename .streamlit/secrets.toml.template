# Streamlit secrets — copy this file to .streamlit/secrets.toml and fill in values.
# DO NOT commit secrets.toml to git. It is already in .gitignore.
#
# For Streamlit Cloud deployment, paste these values into:
#   share.streamlit.io → your app → Settings → Secrets

# Required: your SAP Hyperspace API key (UUID format)
ANTHROPIC_API_KEY = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Required: Hyperspace proxy URL (direct for cloud; localhost for local dev)
# Streamlit Cloud:
ANTHROPIC_BASE_URL = "https://api.hyperspace.tools.sap/llm-proxy/anthropic"
# Local dev (override in your local secrets.toml):
# ANTHROPIC_BASE_URL = "http://localhost:6655/anthropic"

# Required: Hyperspace model ID
ANTHROPIC_MODEL = "anthropic--claude-4.6-opus"

# Optional: shared password for access control
# APP_PASSWORD = "your-shared-password"
