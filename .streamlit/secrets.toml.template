# Streamlit secrets — copy this file to .streamlit/secrets.toml and fill in values.
# DO NOT commit secrets.toml to git. It is already in .gitignore.

# Required: your Anthropic API key (direct API, not Hyperspace)
ANTHROPIC_API_KEY = "sk-ant-..."

# Required for public deployment: shared password for access control
APP_PASSWORD = "your-shared-password"

# Optional overrides (leave blank to use defaults)
# ANTHROPIC_MODEL = "claude-opus-4-6"   # default when using direct API
# ANTHROPIC_BASE_URL = ""               # leave unset for direct API; set to http://localhost:6655/anthropic for Hyperspace
